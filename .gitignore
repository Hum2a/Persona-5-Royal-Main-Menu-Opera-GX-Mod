# --- Large files (GitHub: regular Git rejects blobs ~> 100 MiB) ---
# .gitignore cannot match by file size. To block oversized commits locally:
#   git config core.hooksPath .githooks
# Park huge sources/exports you never want committed:
not-for-github/
screen1.mp4